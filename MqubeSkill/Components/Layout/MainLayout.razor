                <ul class="footer-links">
                    <li><NavLink href="/">Home</NavLink></li>
                    <li><NavLink href="/about">About us</NavLink></li>
                    <li><NavLink href="/services">Services</NavLink></li>
                </ul>
            </div>

            <div class="col-md-2 mb-4">
                <ul class="footer-links mt-4">
                    <li><NavLink href="/register-student">Student Registrations</NavLink></li>
                    <li><NavLink href="/register-tutor">Tutor Registrations</NavLink></li>
                    <li><NavLink href="/testimonials">Testimonials</NavLink></li>
                    <li><NavLink href="/contact">Contact us</NavLink></li>
                </ul>
            </div>


            <!-- Get in Touch -->
            <div class="col-md-3 mb-4">
                <h6 class="footer-title">Get in Touch</h6>
                <ul class="footer-contact">
                    <li>
                        <img src="../images/call.png" alt="">
                        <span>+91 9876543210</span>
                    </li>
                    <li>
                        <img src="../images/mail.png" alt="">
                        <span>skilljourney@gmail.com</span>
                    </li>
                    <li>
                        <img src="../images/web.png" alt="">
