                    </div>

                    <div class="visit-map">
                        <img src="../images/footer.png" alt="Location" class="footer-map-img">
                    </div>
                </div>

                <div class="visit-follow">
                    <span class="follow-text">Follow us</span>
                    <div class="footer-social">
                        <a href="#"><img src="images/ins.png" alt=""></a>
                        <a href="#"><img src="images/fb.png" alt=""></a>
                        <a href="#"><img src="images/wa.png" alt=""></a>
                        <a href="#"><img src="images/x.png" alt=""></a>
                        <a href="#"><img src="images/ll.png" alt=""></a>
                    </div>
                </div>
            </div>

