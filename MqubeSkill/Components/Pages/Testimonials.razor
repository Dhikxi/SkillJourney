@page "/testimonials"

<!-- HERO SECTION -->
<section class="inner-hero">
    <div class="inner-hero-content text-center">
        <h1>What Our Students & Tutors Say</h1>
        <p>
            Real stories – from across the world – highlighting MQube’s impact
        </p>
    </div>
</section>


<!-- TESTIMONIAL CAROUSEL -->
<section class="testimonials-section py-5">
    <div class="container">
        <!-- Slider -->
        <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">

                <!-- Slide 1 -->
                <div class="carousel-item active">
                    <div class="row g-4 justify-content-center">

                        <!-- Testimonial Card -->
                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex" onclick="openTestimonial(
       '/images/testi1.png',
       'Bhavya, USA',
       'Tutor',
       'I have been taking online chemistry classes with MQube Tuitions since 2016.The tutor genuinely takes interest and provides ample resources..'
     )">
                                <img src="/images/testi1.png" class="testimonial-img" alt="Bhavya">
                                <div class="testimonial-content">
                                    <img src="/images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Bhavya, USA</h6>
                                    <small class="text-primary">Tutor</small>
                                    <p>
                                        I have been taking online chemistry classes with MQube Tuitions since 2016.
                                        The tutor genuinely takes interest and provides ample resources.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Testimonial Card -->
                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex" onclick="openTestimonial(
       '/images/testi1.png',
       'Rebacca Bose, Kerala',
       'Student',
       'I am Rebecca Bose, signed up with MQube for NEET biology,The coaching helped me move closer to my dream of becoming a doctor.'
     )">
                                <img src="/images/testi2.png" class="testimonial-img" alt="Rebecca">
                                <div class="testimonial-content">
                                    <img src="/images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Rebecca Bose, Kerala</h6>
                                    <small class="text-primary">Student</small>
                                    <p>
                                        I'm Rebecca Bose, signed up with MQube for NEET biology.
                                        The coaching helped me move closer to my dream of becoming a doctor.
                                    </p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Slide 2 (You can duplicate same structure) -->
                <div class="carousel-item">
                    <div class="row g-4 justify-content-center">

                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex" onclick="openTestimonial(
                                           '/images/testi1.png',
                                           'Ananya, Chennai',
                                           'Parent',
                                           'MQube has transformed my child’s learning journey with personal attention and flexible class timings.'
                                         )">
                                <img src="/images/testi1.png" class="testimonial-img" alt="">
                                <div class="testimonial-content">
                                    <img src="/images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Ananya, Chennai</h6>
                                    <small class="text-primary">Parent</small>
                                    <p>
                                        MQube has transformed my child’s learning journey with personal attention
                                        and flexible class timings.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex" onclick="openTestimonial(
       '/images/testi1.png',
       'Arjun, Bangalore',
       'Student',
       'Excellent tutors and well-structured classes. Monthly assessments helped me improve consistently.'
     )">
                                <img src="/images/testi2.png" class="testimonial-img" alt="">
                                <div class="testimonial-content">
                                    <img src="/images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Arjun, Bangalore</h6>
                                    <small class="text-primary">Student</small>
                                    <p>
                                        Excellent tutors and well-structured classes. Monthly assessments helped
                                        me improve consistently.
                                    </p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <!-- Controls -->
            <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>

    </div>
</section>

<!-- Testimonial Popup Modal -->
<div class="modal fade" id="testimonialModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content testimonial-modal">
            <button type="button"
                    class="btn-close modal-close"
                    onclick="closeTestimonial()"
                    aria-label="Close"></button>


            <div class="modal-body text-center">

                <img id="modalImg" class="modal-profile" src="" alt="Profile">

                <h5 id="modalName" class="mt-3 mb-0 text-black"></h5>
                <small id="modalPlace" class="text-dark"></small>

                <p id="modalText" class="mt-4 text-black"></p>

            </div>

        </div>
    </div>
</div>

