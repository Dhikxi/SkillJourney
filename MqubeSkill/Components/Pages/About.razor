@page "/about"

<!-- ABOUT BANNER -->
<section class="about-banner">
    <div class="container">
        <div class="row">
            <div class="col text-center text-white">
                <h1 class="about-banner-title">About MQube Tuitions</h1>
            </div>
        </div>
    </div>
</section>

<!-- Welcome Section -->
<section class="about-quote-section">
    <div class="container">
        <div class="row align-items-center">

            <!-- Left content -->
            <div class="col-md-6">
                <h2 class="welcome-title">Welcome to MQube Tuitions,</h2>
                <p>
                    The right place for smart education. Be smart with smart
                    classes and get better grades. Step into online tuition with
                    our expert team. Here you can get professional and well-experienced tutors for
                    every subject. We guarantee improvement in your
                    grades. Our experts are ready to distribute their experience
                    with you.
                </p>
            </div>

            <!-- Right quote image -->
            <div class="col-md-6 position-relative">
                <div class="quote-wrapper">
                    <img src="images/abouts.png" class="quote-bg" alt="">
                    <p class="quote-text">
                        No Student Should Be Left Behind <br>
                        Without A Teacher
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Who We Are -->
<section class="who-we-are-section">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-4 col-md-5 text-center mb-4 mb-md-0">
                <div class="who-box mx-auto">
                    <h2>
                        Who<br>
                        we<br>
                        are?
                    </h2>
                </div>
            </div>

            <div class="col-lg-8 col-md-7">
                <div class="who-content">
                    <p>
                        MQube Tuitions is an online educational institute under the able guidance
                        of Mrs. Malathi Ramachandran, one of the pioneers in online tutoring.
                        She holds fourteen years of experience in handling curriculums
                        from 25 different countries including US, Canada, France,
                        India, UAE, UK and many more.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- What We Offer -->
<section class="offer-section">
    <div class="container">
        <h2 class="text-center offer-title">What we offer?</h2>

        <div class="offer-book">
            <div class="row g-4">

                <div class="col-md-6">
                    <ul class="offer-list">
                        <li>Tutoring for every age and almost every subject.</li>
                        <li>All school curriculums – US Common Core, IGCSE, IB, CBSE, Australian & Singapore curriculum.</li>
                        <li>College studies, Olympiads, SAT, ACT, NAPLAN and more.</li>
                        <li>Language proficiency – German, Tamil, Hindi, Spoken English, IELTS and PTE.</li>
                        <li>Music – Carnatic vocal, Veena, Hindustani vocal and instrumental.</li>
                        <li>UPSC / TNPSC mathematics sessions.</li>
                    </ul>
                </div>

                <div class="col-md-6">
                    <ul class="offer-list">
                        <li>Experienced and passionate teachers.</li>
                        <li>Highly qualified tutors with excellent teaching skills.</li>
                        <li>Free demo class before enrollment.</li>
                        <li>Online classes via Skype and Whiteboard.</li>
                        <li>Class notes shared after sessions.</li>
                        <li>Regular homework and monthly assessments.</li>
                    </ul>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- Why Online -->
<section class="why-online-section">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-7 col-md-12">
                <h2 class="why-title">Why Online Tuitions?</h2>
                <ul class="why-list">
                    <li>Online teaching has emerged as a winner in modern education.</li>
                    <li>Teachers can focus on each individual student.</li>
                    <li>Supports students with different learning speeds and capacities.</li>
                </ul>
            </div>

            <div class="col-lg-5 col-md-12 text-center">
                <img src="images/comp.png"
                     alt="Why Online Tuition"
                     class="why-image img-fluid">
            </div>

        </div>
    </div>
</section>

<!-- Why MQube -->
<section class="why-mqube-section">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="why-title">Why MQube Tuitions?</h2>
            <p class="why-subtitle">
                Because every student deserves clarity, confidence, and success.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="why-card">
                    <h5>Live Tutoring</h5>
                    <p>Live Online Tutoring by expert teachers.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card">
                    <h5>Expert Teachers</h5>
                    <p>Carefully selected tutors with deep subject knowledge.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card">
                    <h5>Concept-First Approach</h5>
                    <p>We build logic step by step until concepts are crystal clear.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card">
                    <h5>Skill Assessment</h5>
                    <p>We assess and identify learning gaps before starting sessions.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card">
                    <h5>Flexible Support</h5>
                    <p>Flexible scheduling for tests, assignments and urgencies.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="why-card">
                    <h5>Positive Learning</h5>
                    <p>Encouraging feedback and supportive teaching approach.</p>
                </div>
            </div>

        </div>

        <div class="why-footer mt-5 text-center">
            <p>
                We are thankful to our students and parents for their love,
                support and trust.
            </p>
        </div>

    </div>
</section>
