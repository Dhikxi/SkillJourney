@rendermode InteractiveServer
@page "/tutor-dashboard"

@using MqubeSkill.Data
@using MqubeSkill.Models
@using Microsoft.EntityFrameworkCore
@using MqubeSkill.Services

@inject IDbContextFactory<MQubeDbContext> DbFactory
@inject AuthService AuthService
@inject NavigationManager Nav

<section class="tutor-dashboard-bg">

    @if (tutor == null)
    {
        <div class="container py-5">
            <p>Loading dashboard...</p>
        </div>
    }
    else
    {
        <div class="container py-5">

            <!-- PROFILE CARD -->
            <div class="profile-card mb-4">
                <div class="row align-items-center">

                    <div class="col-md-3 text-center">
                        <img src="/images/12.png" class="tutor-image" />
                    </div>

                    <div class="col-md-9">
                        <h2 class="tutor-name">@tutor.User?.FullName</h2>
                        <p class="tutor-role">Tutor Dashboard</p>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <p><b>Subjects:</b> @tutor.Subjects</p>
                                <p><b>Qualification:</b> @tutor.Qualification</p>
                            </div>

                            <div class="col-md-6">
                                <p><b>Experience:</b> @tutor.ExperienceYears years</p>
                                <p><b>Contact:</b> @tutor.ContactNo</p>

                            </div>
                            <div class="col-md-6">
                                <p><b>Email:</b> @tutor.User?.Email</p>
                                <p>
                                    <b>Available Time:</b>
                                    @(tutor.AvailableStartTime.HasValue && tutor.AvailableEndTime.HasValue
                                        ? $"{tutor.AvailableStartTime.Value.ToString("hh:mm tt")} - {tutor.AvailableEndTime.Value.ToString("hh:mm tt")}"
                                        : "Not set")
                                </p>
                            </div>
                        </div>

                        <button class="btn mt-2 me-2 tutor-chat-btn" @onclick='() => Nav.NavigateTo("/chat")'>
                            💬 My Classes Chat
                        </button>
                        <button class="btn btn-danger mt-2" @onclick="Logout">
                            Logout
                        </button>

                    </div>

                </div>
            </div>

            <!-- SET FEE -->
            <div class="profile-card mb-4">
                <h4>Set Your Fee</h4>

                <div class="row mt-3">
                    <div class="col-md-4">
                        <InputNumber class="form-control"
                                     @bind-Value="tutor.FeePerHour"
                                     step="1" />
                    </div>

                    <div class="col-md-3">
                        <button class="btn btn-warning"
                                @onclick="UpdateFee">
                            Update Fee
                        </button>
                    </div>
                </div>

                <p class="mt-2 text-warning">
                    Current Fee: ₹@tutor.FeePerHour.ToString("0") / hour
                </p>
            </div>

            <div class="profile-card mb-4">
                <h4>Upload Your Payment QR</h4>

                <InputFile OnChange="UploadQr" />

                @if (!string.IsNullOrEmpty(tutor.QrImagePath))
                {
                    <p class="mt-2 text-success">QR Uploaded Successfully</p>

                    <img src="@tutor.QrImagePath"
                         style="width:150px; height:150px; border-radius:10px; margin-top:10px;" />
                }
            </div>

            <div class="profile-card mb-4">
                <h4>Edit Profile</h4>

                <div class="row mt-3">

                    <div class="col-md-4">
                        <InputText class="form-control"
                                   placeholder="Full Name"
                                   @bind-Value="tutor.User!.FullName" />
                    </div>

                    <div class="col-md-4">
                        <InputText class="form-control"
                                   placeholder="Subjects"
                                   @bind-Value="tutor.Subjects" />
                    </div>

                    <div class="col-md-4">
                        <InputText class="form-control"
                                   placeholder="Qualification"
                                   @bind-Value="tutor.Qualification" />
                    </div>

                    <div class="col-md-4 mt-2">
                        <InputNumber class="form-control"
                                     placeholder="Experience (years)"
                                     @bind-Value="tutor.ExperienceYears" />
                    </div>

                    <div class="col-md-4 mt-2">
                        <InputText class="form-control"
                                   placeholder="Contact"
                                   @bind-Value="tutor.ContactNo" />
                    </div>

                    <!-- AVAILABLE TIME -->
                    <div class="col-md-4 mt-2">
                        <input type="time" class="form-control"
                               value="@startTimeString"
                               @onchange="OnStartTimeChanged" />
<small>Start Time</small>
                    </div>

                    <div class="col-md-4 mt-2">
                        <input type="time" class="form-control mt-2"
                               value="@endTimeString"
                               @onchange="OnEndTimeChanged" />
<small>End Time</small>
                    </div>

                    <div class="col-md-3 mt-3">
                        <button class="btn btn-success"
                                @onclick="UpdateProfile">
                            Save Changes
                        </button>
                    </div>

                </div>
            </div>

            <!-- STUDENT REQUESTS -->
            <div class="profile-card">
                <h4>Student Requests</h4>

                @if (requests == null || requests.Count == 0)
                {
                    <p class="mt-3">No student requests yet.</p>
                }
                else
                {
                    <div class="row mt-3">
                        @foreach (var r in requests)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="student-card">

                                    <h6>@r.Student?.User?.FullName</h6>

                                    <p><b>Subject:</b> @r.Subject</p>
                                    <p><b>Grade:</b> @r.Student?.GradeLevel</p>
                                    <p><b>School:</b> @r.Student?.SchoolName</p>
                                    <p><b>Selected Time:</b> @r.SelectedSlot</p>

                                    @if (!string.IsNullOrEmpty(r.SelectedSlot2))
                                    {
                                        <p><b>Second Slot:</b> @r.SelectedSlot2</p>
                                    }

                                    <p><b>Status:</b> @r.Status</p>

                                    @if (r.Status == "Pending")
                                    {
                                        <button class="btn btn-success btn-sm"
                                                @onclick="async () => await AcceptRequest(r.DemoBookingId)">
                                            Accept
                                        </button>

                                        <button class="btn btn-danger btn-sm"
                                                @onclick="async () => await RejectRequest(r.DemoBookingId)">
                                            Reject
                                        </button>
                                    }

                                    @if (r.Status != null && r.Status.Contains("Accepted"))
                                    {
                                        <div class="mt-2">
                                            <InputText class="form-control"
                                                       placeholder="Enter Demo Link"
                                                       @bind-Value="r.DemoLink" />

                                            <button class="btn btn-primary btn-sm mt-2"
                                                    @onclick="() => SaveDemoLink(r.DemoBookingId, r.DemoLink)">
                                                Save Demo Link
                                            </button>
                                        </div>
                                    }

                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- PAYMENT SECTION -->
            <div class="profile-card mt-4">
                <h4>Payment Verification</h4>

                @if (payments == null || payments.Count == 0)
                {
                    <p class="mt-3">No payment submissions yet.</p>
                }
                else
                {
                    <table class="table table-dark mt-3">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Screenshot</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var p in payments)
                            {
                                <tr>

                                    <td>@p.Student?.User?.FullName</td>

                                    <td>
                                        <a href="@p.ScreenshotPath" target="_blank">
                                            View Screenshot
                                        </a>
                                    </td>

                                    <td>
                                        <span class="badge bg-warning">@p.Status</span>

                                        @if (p.Status == "Pending")
                                        {
                                            <button class="btn btn-success btn-sm ms-2"
                                                    @onclick="() => VerifyPayment(p.PaymentId)">
                                                Verify
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

        </div>
    }

</section>

@code {

    Tutor? tutor;
    List<DemoBooking>? requests;
    List<Payment>? payments;
    TimeOnly? availableStartTimeOnly;
    TimeOnly? availableEndTimeOnly;
    string? startTimeString;
    string? endTimeString;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.LoggedInUserId == 0)
        {
            Nav.NavigateTo("/login");
            return;
        }

        var userId = AuthService.LoggedInUserId;

        using var Db = DbFactory.CreateDbContext();

        tutor = await Db.Tutors
            .Include(t => t.User)
            .FirstOrDefaultAsync(t => t.UserId == userId);

        if (tutor == null) return;
        availableStartTimeOnly = tutor.AvailableStartTime;
        availableEndTimeOnly = tutor.AvailableEndTime;

        requests = await Db.DemoBookings
            .Where(d => d.TutorId == tutor.TutorId)
            .Include(d => d.Student)
            .ThenInclude(s => s.User)
            .ToListAsync();

        payments = await Db.Payments
            .Where(p => p.TutorId == tutor.TutorId)
            .Include(p => p.Student)
            .ThenInclude(s => s.User)
            .ToListAsync();

        if (tutor.AvailableStartTime.HasValue)
            startTimeString = tutor.AvailableStartTime.Value.ToString("HH:mm");

        if (tutor.AvailableEndTime.HasValue)
            endTimeString = tutor.AvailableEndTime.Value.ToString("HH:mm");
    }

    async Task UpdateFee()
    {
        using var Db = DbFactory.CreateDbContext();
        var t = await Db.Tutors.FindAsync(tutor!.TutorId);
        if (t == null) return;
        t.FeePerHour = tutor.FeePerHour;
        await Db.SaveChangesAsync();
    }

    async Task AcceptRequest(int bookingId)
    {
        using var Db = DbFactory.CreateDbContext();

        var booking = await Db.DemoBookings
            .FirstOrDefaultAsync(d => d.DemoBookingId == bookingId);

        if (booking == null) return;

        // ✅ GET ALL BOOKINGS IN SAME GROUP
        var groupBookings = await Db.DemoBookings
            .Where(d => d.RequestGroupId == booking.RequestGroupId)
            .ToListAsync();

        // ✅ ACCEPT ALL TOGETHER
        foreach (var item in groupBookings)
        {
            item.Status = "Accepted - Waiting for Demo";
        }

        await Db.SaveChangesAsync();

        await RefreshData();

    }

    async Task RejectRequest(int bookingId)
    {
        using var Db = DbFactory.CreateDbContext();
        var booking = await Db.DemoBookings
            .FirstOrDefaultAsync(d => d.DemoBookingId == bookingId);

        if (booking == null) return;

        booking.Status = "Rejected";
        await Db.SaveChangesAsync();

        await RefreshData();
    }

    async Task SaveDemoLink(int bookingId, string? link)
    {
        using var Db = DbFactory.CreateDbContext();
        var booking = await Db.DemoBookings
            .FirstOrDefaultAsync(d => d.DemoBookingId == bookingId);

        if (booking == null) return;

        booking.DemoLink = link;
        booking.Status = "Demo Scheduled";
        await Db.SaveChangesAsync();

        await RefreshData();
    }

    async Task UploadQr(InputFileChangeEventArgs e)
    {
        var file = e.File;

        var folderPath = Path.Combine("wwwroot", "qr");
        if (!Directory.Exists(folderPath))
            Directory.CreateDirectory(folderPath);

        var fileName = Guid.NewGuid() + Path.GetExtension(file.Name);
        var filePath = Path.Combine(folderPath, fileName);

        using var stream = new FileStream(filePath, FileMode.Create);
        await file.OpenReadStream().CopyToAsync(stream);

        using var Db = DbFactory.CreateDbContext();
        var t = await Db.Tutors.FindAsync(tutor!.TutorId);
        if (t == null) return;

        t.QrImagePath = "/qr/" + fileName;
        tutor.QrImagePath = t.QrImagePath;

        await Db.SaveChangesAsync();
    }

    async Task VerifyPayment(int paymentId)
    {
        using var Db = DbFactory.CreateDbContext();

        var payment = await Db.Payments
            .FirstOrDefaultAsync(p => p.PaymentId == paymentId);

        if (payment == null) return;

        payment.Status = "Verified";
        await Db.SaveChangesAsync();

        var existingEnrollment = await Db.Enrollments
            .FirstOrDefaultAsync(e =>
                e.StudentId == payment.StudentId &&
                e.TutorId == payment.TutorId);

        if (existingEnrollment == null)
        {
            var demoBooking = await Db.DemoBookings
    .Where(d =>
        d.StudentId == payment.StudentId &&
        d.TutorId == payment.TutorId &&
        d.Status != null &&
        d.Status.Contains("Accepted"))
    .OrderByDescending(d => d.DemoBookingId)
    .FirstOrDefaultAsync();

            if (demoBooking == null) return;

            var subjectId = demoBooking.SubjectId;

            var enrollment = new Enrollment
            {
                StudentId = payment.StudentId,
                TutorId = payment.TutorId,
                SubjectId = subjectId,
                StartDate = DateTime.Now,
                Status = "Active",
                PaymentStatus = "Verified"
            };

            Db.Enrollments.Add(enrollment);
            await Db.SaveChangesAsync();
        }

        await RefreshData();
    }

    async Task RefreshData()
    {
        using var Db = DbFactory.CreateDbContext();

        requests = await Db.DemoBookings
            .Where(d => d.TutorId == tutor!.TutorId)
            .Include(d => d.Student)
            .ThenInclude(s => s.User)
            .ToListAsync();

        payments = await Db.Payments
            .Where(p => p.TutorId == tutor!.TutorId)
            .Include(p => p.Student)
            .ThenInclude(s => s.User)
            .ToListAsync();

        StateHasChanged();
    }

    void Logout()
    {
        AuthService.Logout();
        Nav.NavigateTo("/login");
    }

    async Task UpdateProfile()
    {
        using var Db = DbFactory.CreateDbContext();

        var t = await Db.Tutors
            .Include(x => x.User)
            .FirstOrDefaultAsync(x => x.TutorId == tutor!.TutorId);

        if (t == null) return;

        t.Subjects = tutor.Subjects;
        t.Qualification = tutor.Qualification;
        t.ExperienceYears = tutor.ExperienceYears;
        t.ContactNo = tutor.ContactNo;

        if (t.User != null)
        {
            t.User.FullName = tutor.User!.FullName;
        }

        // Save available time
        if (availableStartTimeOnly.HasValue)
            t.AvailableStartTime = availableStartTimeOnly;

        if (availableEndTimeOnly.HasValue)
            t.AvailableEndTime = availableEndTimeOnly;

        await Db.SaveChangesAsync();
    }
    void OnStartTimeChanged(ChangeEventArgs e)
    {
        startTimeString = e.Value?.ToString();

        if (TimeOnly.TryParse(startTimeString, out var time))
            availableStartTimeOnly = time;
    }

    void OnEndTimeChanged(ChangeEventArgs e)
    {
        endTimeString = e.Value?.ToString();

        if (TimeOnly.TryParse(endTimeString, out var time))
            availableEndTimeOnly = time;
    }

}

<style>

    .tutor-dashboard-bg {
        min-height: 100vh;
        background: linear-gradient(135deg,#0f172a,#1e293b);
        padding-top: 90px;
        color: white;
    }

    .profile-card {
        background: #1e293b;
        border-radius: 14px;
        padding: 28px;
        border: 1px solid rgba(255,255,255,0.05);
        box-shadow: 0 12px 25px rgba(0,0,0,0.45);
        transition: 0.25s ease;
    }

        .profile-card:hover {
            transform: translateY(-3px);
        }

    .tutor-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #facc15;
        box-shadow: 0 0 12px rgba(250,204,21,0.6);
    }

    .tutor-name {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .tutor-role {
        color: #facc15;
        letter-spacing: 1px;
        font-size: 13px;
    }

    .student-card {
        background: #0f172a;
        border-radius: 12px;
        padding: 18px;
        border: 1px solid rgba(255,255,255,0.05);
        transition: 0.25s;
    }

        .student-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

    input.form-control {
        background: #020617;
        border: 1px solid #334155;
        color: white;
    }

        input.form-control:focus {
            border-color: #3b82f6;
            box-shadow: none;
        }

    .btn {
        border-radius: 8px;
        font-weight: 500;
    }

    .btn-warning {
        background: #facc15;
        border: none;
        color: black;
    }

        .btn-warning:hover {
            background: #eab308;
        }

    .btn-success {
        background: #22c55e;
        border: none;
    }

        .btn-success:hover {
            background: #16a34a;
        }

    .btn-danger {
        background: #ef4444;
        border: none;
    }

        .btn-danger:hover {
            background: #dc2626;
        }

    .btn-primary {
        background: #3b82f6;
        border: none;
    }

        .btn-primary:hover {
            background: #2563eb;
        }

    .table-dark {
        background: #020617;
        border-radius: 10px;
        overflow: hidden;
    }

        .table-dark th {
            border-color: #334155;
            font-weight: 500;
        }

        .table-dark td {
            border-color: #334155;
        }

    .badge {
        font-size: 12px;
        padding: 6px 10px;
    }

    a {
        color: #38bdf8;
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
        }

    .tutor-chat-btn {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white !important;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        padding: 8px 22px;
        text-decoration: none !important;
        box-shadow: 0 4px 12px rgba(79,70,229,0.35);
        transition: all 0.2s ease;
    }

        .tutor-chat-btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }
</style>