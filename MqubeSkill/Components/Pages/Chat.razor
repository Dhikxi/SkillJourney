    .btn-review-hw { background: linear-gradient(135deg, #059669, #10b981); color: white; border: none; border-radius: 6px; padding: 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer; }

    /* Progress Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .stat-card { background: #0f172a; border-radius: 12px; padding: 16px; border: 1px solid rgba(255,255,255,0.07); text-align: center; }
    .stat-icon { font-size: 22px; margin-bottom: 8px; }
    .stat-value { color: #f1f5f9; font-size: 20px; font-weight: 700; }
