</style>

@code {
    private string errorMessage = "";
    List<ClassSession> sessions = new();
    int slotCount = 1;
int durationMinutes => slotCount * 60;
    Dictionary<int, string> submissionTexts = new();
Dictionary<int, IBrowserFile> uploadedFiles = new();
    

    [Parameter] public int EnrollmentId { get; set; }

    private User? currentUser;
    private List<Enrollment>? enrollments;
    private Enrollment? selectedEnrollment;
    private List<ChatMessage>? messages;
    private List<Attendance>? attendances;
    private List<Homework>? homeworks;
    private List<Assessment>? assessments;

    private string activeTab = "chat";
    private string newMessage = "";
    private string classLinkInput = "";
    private bool showLinkInput = false;

    // Session fields
    private string newSessionTitle = "";
    private string newSessionLink = "";
    private DateTime newSessionDate = DateTime.Now.AddDays(1);

    // Homework fields
    private string hwTitle = "";
    private string hwDescription = "";
    private DateTime? hwDueDate;
    private string hwRemarks = "";

    // Assessment fields
    private string assessTitle = "";
    private int assessMarks = 0;
    private int assessTotal = 100;
    private string assessRemarks = "";

    // Progress stats
    private int attendancePercent = 0;
    private int submittedHw = 0;
    private int totalHw = 0;
    private int avgMarks = 0;
    private int totalSessions = 0;

    protected override async Task OnInitializedAsync()
    {
        homeworks = await ChatService.GetHomeworksAsync(EnrollmentId);
        var userId = AuthService.LoggedInUserId;
        if (userId == 0) { Navigation.NavigateTo("/login"); return; }

        currentUser = await ChatService.GetUserAsync(userId);
        if (currentUser == null) return;

        enrollments = await ChatService.GetEnrollmentsForUserAsync(currentUser.UserId, currentUser.Role!);

        if (EnrollmentId > 0)
            await SelectEnrollment(EnrollmentId);
        else if (enrollments.Count > 0)
            await SelectEnrollment(enrollments[0].EnrollmentId);

        _ = Task.Run(async () =>
{
    while (true)
    {
        await Task.Delay(3000); // every 3 seconds

        if (EnrollmentId > 0)
        {
            messages = await ChatService.GetMessagesAsync(EnrollmentId);
            await InvokeAsync(StateHasChanged);
        }
    }
});
    }

    private async Task SelectEnrollment(int enrollmentId)
    {
        EnrollmentId = enrollmentId;
        selectedEnrollment = await ChatService.GetEnrollmentAsync(enrollmentId);
        sessions = await ChatService.GetSessionsAsync(enrollmentId);
        activeTab = "chat";
        await LoadTabData();
        StateHasChanged();
    }

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        await LoadTabData();
        StateHasChanged();
    }

    private async Task LoadTabData()
    {
        if (activeTab == "chat")
            messages = await ChatService.GetMessagesAsync(EnrollmentId);

        if (activeTab == "attendance")
        {
            sessions = await ChatService.GetSessionsAsync(EnrollmentId);
            attendances = await ChatService.GetAttendancesAsync(EnrollmentId);
        }

        if (activeTab == "homework")
            homeworks = await ChatService.GetHomeworksAsync(EnrollmentId);

        if (activeTab == "progress")
        {
            sessions = await ChatService.GetSessionsAsync(EnrollmentId);
            attendances = await ChatService.GetAttendancesAsync(EnrollmentId);
            homeworks = await ChatService.GetHomeworksAsync(EnrollmentId);
            assessments = await ChatService.GetAssessmentsAsync(EnrollmentId);
            CalculateStats();
        }
    }

    private void CalculateStats()
    {
        totalSessions = sessions?.Count ?? 0;
        var present = attendances?.Count(a => a.Status == "Present") ?? 0;
        var totalAtt = attendances?.Count ?? 0;
        attendancePercent = totalAtt > 0 ? (present * 100 / totalAtt) : 0;

        totalHw = homeworks?.Count ?? 0;
        submittedHw = homeworks?.Count(h => h.Status == "Submitted" || h.Status == "Reviewed") ?? 0;

        if (assessments != null && assessments.Count > 0)
        {
            var total = assessments.Sum(a => a.TotalMarks > 0 ? (a.MarksObtained * 100 / a.TotalMarks) : 0);
            avgMarks = total / assessments.Count;
        }
        else avgMarks = 0;
    }

    private async Task SendText()
    {
        if (string.IsNullOrWhiteSpace(newMessage) || currentUser == null) return;
        await ChatService.SendMessageAsync(EnrollmentId, currentUser.UserId, newMessage, "Text");
        newMessage = "";
        messages = await ChatService.GetMessagesAsync(EnrollmentId);
        StateHasChanged();
    }

    private async Task SendClassLink()
    {
        if (string.IsNullOrWhiteSpace(classLinkInput) || currentUser == null) return;
        await ChatService.SendMessageAsync(EnrollmentId, currentUser.UserId, classLinkInput, "ClassLink");
        classLinkInput = "";
        showLinkInput = false;
        messages = await ChatService.GetMessagesAsync(EnrollmentId);
        StateHasChanged();
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendText();
    }

    private async Task CreateSession()
{
    if (string.IsNullOrWhiteSpace(newSessionTitle)) return;

    var newStart = newSessionDate;
    var newEnd = newSessionDate.AddMinutes(durationMinutes);

    // 🔴 CHECK CLASH
    var isClashing = sessions.Any(s =>
    {
        var existingStart = s.ScheduledAt;
        var existingEnd = s.ScheduledAt.AddMinutes(s.DurationMinutes);

        return newStart < existingEnd && newEnd > existingStart;
    });

    if (isClashing)
{
    errorMessage = "⚠️ This time slot is already booked!";
    return;
}

    // ✅ NO CLASH → CREATE
    await ChatService.CreateSessionAsync(
        EnrollmentId,
        newSessionTitle,
        string.IsNullOrEmpty(newSessionLink) ? null : newSessionLink,
        newSessionDate,
        durationMinutes
    );
    errorMessage = "";
    newSessionTitle = "";
    newSessionLink = "";
    newSessionDate = DateTime.Now.AddDays(1);

    sessions = await ChatService.GetSessionsAsync(EnrollmentId);
    StateHasChanged();
}

    private async Task MarkAtt(int sessionId, string status)
    {
        var studentId = await ChatService.GetStudentIdByEnrollmentAsync(EnrollmentId);
        if (studentId == null) return;
        await ChatService.MarkAttendanceAsync(sessionId, studentId.Value, status);
        attendances = await ChatService.GetAttendancesAsync(EnrollmentId);
        StateHasChanged();
    }

    private async Task CompleteSession(int sessionId)
    {
        await ChatService.CompleteSessionAsync(sessionId);
        sessions = await ChatService.GetSessionsAsync(EnrollmentId);
        StateHasChanged();
    }

    private async Task AssignHomework()
    {
        if (string.IsNullOrWhiteSpace(hwTitle)) return;
        await ChatService.AssignHomeworkAsync(EnrollmentId, hwTitle,
            string.IsNullOrEmpty(hwDescription) ? null : hwDescription, hwDueDate);
        hwTitle = ""; hwDescription = ""; hwDueDate = null;
        homeworks = await ChatService.GetHomeworksAsync(EnrollmentId);
        StateHasChanged();
    }

async Task SubmitHomework(int homeworkId)
{
    string filePath = "";

    if (uploadedFiles.ContainsKey(homeworkId) && uploadedFiles[homeworkId] != null)
    {
        var file = uploadedFiles[homeworkId];

        var folderPath = Path.Combine("wwwroot", "uploads");

        if (!Directory.Exists(folderPath))
        {
            Directory.CreateDirectory(folderPath);
        }

        var fileName = Guid.NewGuid() + Path.GetExtension(file.Name);
        var fullPath = Path.Combine(folderPath, fileName);

        using var stream = new FileStream(fullPath, FileMode.Create);
        await file.OpenReadStream().CopyToAsync(stream);

        filePath = "/uploads/" + fileName;
    }

    var text = submissionTexts.ContainsKey(homeworkId)
        ? submissionTexts[homeworkId]
        : "";

    await ChatService.SubmitHomeworkAsync(homeworkId, text, filePath);

    // clear only this homework data
    submissionTexts.Remove(homeworkId);
    uploadedFiles.Remove(homeworkId);

    // reload list
    homeworks = await ChatService.GetHomeworksAsync(EnrollmentId);

    StateHasChanged();
}

    private async Task ReviewHomework(int homeworkId)
    {
        await ChatService.UpdateHomeworkStatusAsync(homeworkId, "Reviewed",
            string.IsNullOrEmpty(hwRemarks) ? null : hwRemarks);
        hwRemarks = "";
        homeworks = await ChatService.GetHomeworksAsync(EnrollmentId);
        StateHasChanged();
    }

    private async Task AddAssessment()
    {
        if (string.IsNullOrWhiteSpace(assessTitle) || assessTotal == 0) return;
        await ChatService.AddAssessmentAsync(EnrollmentId, assessTitle, assessMarks, assessTotal,
            string.IsNullOrEmpty(assessRemarks) ? null : assessRemarks);
        assessTitle = ""; assessMarks = 0; assessTotal = 100; assessRemarks = "";
        assessments = await ChatService.GetAssessmentsAsync(EnrollmentId);
        CalculateStats();
        StateHasChanged();
    }

    async Task HandleFileUpload(InputFileChangeEventArgs e, int homeworkId)
{
    uploadedFiles[homeworkId] = e.File;
}
}