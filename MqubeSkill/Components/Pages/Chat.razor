    .assess-remarks { color: #94a3b8; font-size: 11px; margin-top: 2px; }
    .assess-score { text-align: right; min-width: 100px; }
    .score-num { color: #f1f5f9; font-size: 13px; font-weight: 600; }
    .score-bar { background: #1e293b; border-radius: 4px; height: 6px; margin: 4px 0; overflow: hidden; }
    .score-fill { height: 100%; border-radius: 4px; transition: width 0.3s; }
    .fill-green { background: #22c55e; }
    .fill-amber { background: #fbbf24; }
    .fill-red { background: #ef4444; }
    .score-pct { color: #64748b; font-size: 11px; }

    /* Messages */
    .chat-messages { flex: 1; overflow-y: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 12px; background: #1e293b; }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }

    .msg-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #475569; gap: 8px; margin-top: 60px; }
    .msg-empty-icon { font-size: 40px; }

    .msg-row { display: flex; align-items: flex-end; gap: 8px; }
    .msg-row.mine { justify-content: flex-end; }
    .msg-row.theirs { justify-content: flex-start; }

    .msg-avatar { width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }

    .msg-bubble { max-width: 60%; padding: 12px 16px; border-radius: 18px; font-size: 14px; line-height: 1.55; word-break: break-word; }
    .bubble-mine { background: linear-gradient(135deg, #4f46e5, #6d28d9); color: white; border-bottom-right-radius: 4px; }
    .bubble-theirs { background: #0f172a; color: #e2e8f0; border-bottom-left-radius: 4px; border: 1px solid rgba(255,255,255,0.07); }
    .bubble-special { background: rgba(250,204,21,0.08) !important; border: 1.5px solid rgba(250,204,21,0.3) !important; color: #f1f5f9 !important; border-bottom-left-radius: 4px; }

    .msg-type-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #facc15; margin-bottom: 6px; }
    .msg-text { color: inherit; }
    .msg-time { font-size: 10px; margin-top: 6px; text-align: right; opacity: 0.5; }

    .join-btn { display: inline-block; margin-top: 6px; padding: 8px 18px; background: linear-gradient(135deg, #059669, #10b981); color: white !important; border-radius: 10px; font-size: 13px; font-weight: 600; text-decoration: none !important; }

    .chat-input-area { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.07); background: #0f172a; }
    .link-input-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; padding: 10px 14px; background: rgba(250,204,21,0.06); border-radius: 12px; border: 1px solid rgba(250,204,21,0.2); }
    .link-input-bar .form-control { background: #1e293b; border: 1px solid #334155; color: white; border-radius: 8px; font-size: 13px; }
    .btn-send-link { background: linear-gradient(135deg, #059669, #10b981); color: white; border: none; border-radius: 8px; padding: 6px 16px; font-size: 13px; font-weight: 600; cursor: pointer; white-space: nowrap; }
    .btn-cancel { background: rgba(255,255,255,0.07); color: #94a3b8; border: none; border-radius: 8px; padding: 6px 10px; cursor: pointer; font-size: 13px; }

    .input-row { display: flex; align-items: center; gap: 10px; background: #1e293b; border-radius: 30px; padding: 6px 6px 6px 16px; border: 1.5px solid #334155; transition: border-color 0.2s; }
    .input-row:focus-within { border-color: #4f46e5; }
    .msg-input { flex: 1; background: transparent; border: none; outline: none; color: #f1f5f9; font-size: 14px; padding: 6px 0; }
    .msg-input::placeholder { color: #475569; }
    .btn-icon { background: rgba(255,255,255,0.07); border: none; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; flex-shrink: 0; }
    .btn-send { background: linear-gradient(135deg, #4f46e5, #6d28d9); color: white; border: none; border-radius: 24px; padding: 8px 22px; font-size: 13px; font-weight: 600; cursor: pointer; flex-shrink: 0; }

    .chat-empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8; gap: 12px; text-align: center; }
    .chat-empty-state h5 { color: white; }
    .chat-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #475569; gap: 10px; }
    .empty-icon { font-size: 48px; }
    .btn-back-dash { margin-top: 8px; padding: 10px 24px; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 14px; }

    .chat-loading { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #64748b; gap: 12px; }
    .spinner { width: 32px; height: 32px; border: 3px solid #334155; border-top-color: #4f46e5; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    @@media (max-width: 600px) {
        .chat-sidebar { width: 200px; min-width: 200px; }
        .msg-bubble { max-width: 80%; }
        .chat-body { padding: 12px; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
