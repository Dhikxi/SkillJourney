            <!-- Subject Cards -->
            <div class="col-lg-2 col-md-3 col-sm-4 col-6">
                <div class="subject-card">
                    <img src="/images/tamil.png" alt="">
                    <p>Tamil</p>
                </div>
            </div>

            <div class="col-lg-2 col-md-3 col-sm-4 col-6">
