@page "/services"

<!-- HERO SECTION -->
<section class="services-hero">
    <div class="services-overlay"></div>

    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8 col-md-10">
                <h1 class="services-title">Services</h1>
            </div>
        </div>
    </div>
</section>


<!-- SERVICES LIST SECTION -->
<section class="services-section py-5">
    <img src="/images/corner.png" class="corner-img top-left" alt="">

    <div class="container">

        <!-- Row 1 -->
        <div class="service-row move-right">
            <div class="service-icon blue">
                <img src="/images/1.png" alt="">
            </div>
            <div class="service-content">
                <h5>Online Tuition Support</h5>
                <p>Expert tutors skilled in their subjects, committed to helping students achieve their best through quality education.</p>
            </div>
        </div>

        <!-- Row 2 -->
        <div class="service-row move-left reverse">
            <div class="service-content">
                <h5>Exam and Homework Assistance</h5>
                <p>Worksheets, homework, and lesson-end questions ensure student understanding and effective evaluation.</p>
            </div>
            <div class="service-icon green">
                <img src="/images/2.png" alt="">
            </div>
        </div>

        <!-- Row 3 -->
        <div class="service-row move-right">
            <div class="service-icon blue">
                <img src="/images/3.png" alt="">
            </div>
            <div class="service-content">
                <h5>Language Mastery</h5>
                <p>Special classes in Tamil, Hindi, Arabic & English to build confidence in reading, writing, and speaking.</p>
            </div>
        </div>

        <!-- Row 4 -->
        <div class="service-row move-left reverse">
            <div class="service-content">
                <h5>Music Classes</h5>
                <p>We offer Carnatic, Hindustani, Vocal music classes and musical instruments like Violin, Piano and Veena.</p>
            </div>
            <div class="service-icon green">
                <img src="/images/4.png" alt="">
            </div>
        </div>

        <!-- Row 5 -->
        <div class="service-row move-right">
            <div class="service-icon blue">
                <img src="/images/5.png" alt="">
            </div>
            <div class="service-content">
                <h5>Free Trial Sessions</h5>
                <p>We offer an absolutely free trial class for each student right after registration.</p>
            </div>
        </div>

    </div>

    <img src="/images/corner.png" class="corner-img bottom-right" alt="">
</section>


