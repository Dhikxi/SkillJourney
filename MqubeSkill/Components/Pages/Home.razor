@page "/"

<section class="hero-section">
    <div class="container text-center text-white">

        <h6 class="hero-subtitle">One to One Tuition</h6>

        <h1 class="hero-title">
            Looking for strong concepts and better grades?
        </h1>

        <h2 class="hero-title-secondary">
            Your search ends here.
        </h2>

        <p class="hero-description">
            Live online classes with expert tutors across subjects, languages,
            competitive exams, and even music – flexible scheduling, notes,
            homework, and monthly assessments.
        </p>

        <!-- Stats -->
        <div class="row hero-stats mt-5 text-center g-4">
            <div class="col-md-4">
                <h2 class="stat-number">20+</h2>
                <p class="stat-text">Years</p>
            </div>
            <div class="col-md-4">
                <h2 class="stat-number">2000+</h2>
                <p class="stat-text">Students</p>
            </div>
            <div class="col-md-4">
                <h2 class="stat-number">600+</h2>
                <p class="stat-text">Tutors</p>
            </div>
        </div>

        <!-- Buttons -->
        <div class="hero-buttons mt-4 d-flex justify-content-center flex-wrap gap-3">
            <a href="free-demo.html" class="btn btn-warning me-3 px-4">
                Get a Free Demo
            </a>
            <a href="services.html" class="btn btn-outline-light px-4">
                View Services
            </a>
        </div>

    </div>
</section>

<section class="about-preview-section py-5">
    <div class="container">
        <div class="row align-items-center">

            <!-- Left Content -->
            <div class="col-md-6 order-2 order-md-1 mb-4 mb-md-0">

                <h2 class="section-title">About us</h2>

                <p class="about-text">
                    Welcome to MQube Tuitions, the right place for smart education.
                    Be smart with smart classes and get better grades. Step into online
                    tuition with our expert team. Here you can get professional and
                    well-experienced tutors for every subject.We guarantee improvement
                    in your grades. Our experts are ready to distribute their experience
                    with you to delight your future now and
                    ahead.
                </p>
            </div>


            <!-- Right Image -->
            <div class="col-md-6 order-1 order-md-2 text-center mb-4 mb-md-0">
                <div class="about-image-wrapper">
                    <img src="images/inabout.png"
                         alt="No Student Should Be Left Behind Without A Teacher"
                         class="img-fluid about-image">

                    <!-- Text on yellow circle -->
                    <div class="about-circle-text">
                        <p>No student should be left behind<br>without a teacher</p>

                    </div>

                </div><br><br>
                <a href="/about" class="about-more-btn">
                    More <span>→</span>
                </a>

            </div>

        </div>

    </div>
</section>

<section class="register-simple-section py-5">
    <div class="container text-center text-white">

        <h2 class="section-title mb-4">Register Now</h2>

        <div class="row justify-content-center g-4">

            <!-- Teacher -->
            <div class="col-6 col-md-4">
                <a href="/register-tutor" class="register-link">
                    <div class="register-img-box">
                        <img src="images/teacher.png"
                             class="img-fluid register-img"
                             alt="For Teachers">
                    </div>
                    <p class="register-text mt-3">For Teachers</p>
                </a>
            </div>

            <!-- Student -->
            <div class="col-6 col-md-4">
                <a href="/register-student" class="register-link">
                    <div class="register-img-box">
                        <img src="images/student.png"
                             class="img-fluid register-img"
                             alt="For Students">
                    </div>
                    <p class="register-text mt-3">For Students</p>
                </a>
            </div>

            <!-- Free Demo -->
            <div class="col-6 col-md-4">
                <a href="free-demo.html" class="register-link">
                    <div class="register-img-box">
                        <img src="images/demo.png"
                             class="img-fluid register-img"
                             alt="For Free Demo">
                    </div>
                    <p class="register-text mt-3">For Free Demo</p>
                </a>
            </div>

        </div>

    </div>
</section>

<section class="testimonials-section py-5">
    <div class="container">

        <!-- Section Title -->
        <h2 class="section-title mb-5">Testimonials</h2>

        <!-- Slider -->
        <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">

                <!-- Slide 1 -->
                <div class="carousel-item active">
                    <div class="row g-4 justify-content-center">

                        <!-- Testimonial Card -->
                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex">
                                <img src="images/testi1.png" class="testimonial-img" alt="Bhavya">
                                <div class="testimonial-content">
                                    <img src="images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Bhavya, USA</h6>
                                    <small class="text-primary">Tutor</small>
                                    <p>
                                        I have been taking online chemistry classes with MQube Tuitions since 2016.
                                        The tutor genuinely takes interest and provides ample resources.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Testimonial Card -->
                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex">
                                <img src="images/testi2.png" class="testimonial-img" alt="Rebecca">
                                <div class="testimonial-content">
                                    <img src="images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Rebecca Bose, Kerala</h6>
                                    <small class="text-primary">Student</small>
                                    <p>
                                        I'm Rebecca Bose, signed up with MQube for NEET biology.
                                        The coaching helped me move closer to my dream of becoming a doctor.
                                    </p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Slide 2 (You can duplicate same structure) -->
                <div class="carousel-item">
                    <div class="row g-4 justify-content-center">

                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex">
                                <img src="images/testi1.png" class="testimonial-img" alt="">
                                <div class="testimonial-content">
                                    <img src="images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Ananya, Chennai</h6>
                                    <small class="text-primary">Parent</small>
                                    <p>
                                        MQube has transformed my child’s learning journey with personal attention
                                        and flexible class timings.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="testimonial-card h-100 d-flex">
                                <img src="images/testi2.png" class="testimonial-img" alt="">
                                <div class="testimonial-content">
                                    <img src="images/greenquote.png" class="quote-icon" alt="quote">
                                    <h6>Arjun, Bangalore</h6>
                                    <small class="text-primary">Student</small>
                                    <p>
                                        Excellent tutors and well-structured classes. Monthly assessments helped
                                        me improve consistently.
                                    </p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <!-- Controls -->
            <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>

    </div>
</section>

